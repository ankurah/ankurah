{
  "roles": {
    "Admin": [
      "*"
    ],
    "Editor": [
      "view_posts",
      "manage_posts",
      "view_comments",
      "manage_comments",
      "view_users",
      "read_schema",
      "define_schema"
    ],
    "Author": [
      "view_posts",
      "create_posts",
      "view_comments",
      "create_comments",
      "view_users",
      "read_schema",
      "define_schema"
    ],
    "Reader": [
      "view_published_posts",
      "view_comments",
      "create_comments",
      "read_schema"
    ]
  },
  "collections": {
    "post": {
      "read": "view_posts",
      "write": "manage_posts",
      "scope": [
        {
          "filter": "author = $jwt.sub",
          "unless_privilege": "manage_posts"
        }
      ]
    },
    "comment": {
      "read": "view_comments",
      "write": "manage_comments"
    },
    "user": {
      "read": "view_users",
      "write": "manage_users"
    },
    "tag": {
      "read": "view_posts",
      "write": "manage_posts"
    },
    "_ankurah_model": {
      "read": "read_schema",
      "write": "define_schema"
    },
    "_ankurah_property": {
      "read": "read_schema",
      "write": "define_schema"
    },
    "_ankurah_model_property": {
      "read": "read_schema",
      "write": "define_schema"
    }
  }
}